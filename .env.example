# Application Control
RESET_STATE=false
DEBUG=false

# Logging Configuration
LOG_DEBUG=false

# Directory Configuration
AUDIO_DIR=media/audiobooks
CACHE_DIR=cache
OUTPUT_DIR=media/transcriptions

# Database Configuration (Required)
DB_HOST=db
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=audio

# Processing Configuration
CHUNK_SIZE=1024

# OpenAI Configuration (Required)
OPENAI_API_KEY=sk-proj-
OPENAI_BASE_URL=https://api.openai.com/v1

# LLM Text Correction Configuration
LLM_CORRECTION_ENABLED=false
LLM_CORRECTION_MODEL=gpt-4o-mini
LLM_CORRECTION_BASE_URL=https://api.openai.com/v1
LLM_CORRECTION_API_KEY=sk-proj-
LLM_CORRECTION_TEMPERATURE=0.1
LLM_CORRECTION_MAX_RETRIES=3
LLM_CORRECTION_MAX_TOKENS=4000

# Rate Limiting and Cost Control
LLM_CORRECTION_RATE_LIMIT=10
LLM_CORRECTION_DAILY_BUDGET=10.0
LLM_CORRECTION_TIMEOUT_MIN=30

# MCP Server Configuration
MCP_TRANSPORT=stdio
MCP_HTTP_ADDR=:8081