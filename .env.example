# Required
DATABASE_URL=postgres://lilbro_whisper:password@localhost:5432/lilbro_whisper

# Optional — defaults shown
BOOKS_DIR=/books
EMBEDDINGS_BASE_URL=http://ollama.external-services:11434/v1
EMBEDDINGS_MODEL=nomic-embed-text
MCP_HTTP_ADDR=:8081
STALE_JOB_TIMEOUT=30m
CHUNK_SIZE=512
DEBUG=false

# Optional — library layout for dashboard author/title labels (JSON array).
# Empty → generic fallback. See docs/CONTRACT.md §2.4.
# LIBRARY_COLLECTIONS=[{"root":"audio-libation","layout":"author/title"},{"root":"audio-libro","layout":"author"}]

# Optional — bearer token for the JSON control API (PUT/POST/DELETE /api/v1/pipeline/*).
# Empty → those mutating endpoints fail closed (503). Read endpoints stay open.
# CONTROL_API_TOKEN=
