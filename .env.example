# Required
DATABASE_URL=postgres://earmark:password@localhost:5432/earmark

# Optional — defaults shown
BOOKS_DIR=/books
EMBEDDINGS_BASE_URL=http://ollama.external-services:11434/v1
EMBEDDINGS_MODEL=nomic-embed-text
MCP_HTTP_ADDR=:8081
STALE_JOB_TIMEOUT=30m
CHUNK_SIZE=512
DEBUG=false

# Optional — library layout for dashboard author/title labels (JSON array).
# Empty → generic fallback. See docs/CONTRACT.md §2.4.
# LIBRARY_COLLECTIONS=[{"root":"audio-libation","layout":"author/title"},{"root":"audio-libro","layout":"author"}]

# Optional — bearer token for the JSON control API (PUT/POST/DELETE /api/v1/pipeline/*).
# Empty → those mutating endpoints fail closed (503). Read endpoints stay open.
# CONTROL_API_TOKEN=

# Optional — transcription servers (ASR runners) for the Servers dashboard page
# (JSON array). Lets a configured-but-idle fallback appear, not just servers
# already observed. Read-only; does NOT route work. Add a per-server
# "gpuArbiterUrl" (a gpu-arbiter /status endpoint) for live ready/busy/offline
# readiness. See docs/CONTRACT.md §2.4.
#
# Each entry also takes an optional backend descriptor (CONTRACT §2.13), all
# additive/back-compat:
#   family       — free-form model family id, e.g. "nemo-parakeet", "whisper"
#   runtime      — free-form runtime id, e.g. "nemo-cuda", "whisper.cpp-sycl"
#   capabilities — declared capabilities; keys are the closed enum
#                  (word_timestamps, context_biasing, diarization,
#                   confidence_scores, language_detection) → bool. Unknown keys
#                  are dropped with a warning.
#   languages    — ISO-639-1 codes the backend supports (optional; omit = unknown)
# ASR_SERVERS=[{"name":"gpu-1","host":"gpu-1","model":"nvidia/parakeet-tdt-0.6b-v3","role":"primary","gpuArbiterUrl":"http://gpu-1:48750/status","family":"nemo-parakeet","runtime":"nemo-cuda","capabilities":{"word_timestamps":true,"context_biasing":false,"diarization":false},"languages":["en","es","fr","de"]},{"name":"mac-1","host":"mac-1","model":"nvidia/parakeet-tdt-0.6b-v3","role":"fallback","family":"nemo-parakeet","runtime":"parakeet-mlx","capabilities":{"word_timestamps":true}},{"name":"cpu-1","host":"cpu-1","role":"fallback","family":"whisper","runtime":"whisper.cpp"}]
